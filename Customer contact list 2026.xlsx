/* ============================================================
   VANGUARD BUSINESS SOLUTIONS — SPACING TOKENS
   4px base unit. Used for padding, gaps, and layout rhythm.
   ============================================================ */

:root {
  --space-0: 0px;
  --space-1: 2px;
  --space-2: 4px;
  --space-3: 8px;
  --space-4: 12px;
  --space-5: 16px;
  --space-6: 20px;
  --space-7: 24px;
  --space-8: 32px;
  --space-9: 40px;
  --space-10: 48px;
  --space-11: 64px;
  --space-12: 80px;
  --space-13: 96px;
  --space-14: 128px;

  /* Layout */
  --container-max: 1280px;
  --container-narrow: 760px;
  --page-gutter: 40px;
}
